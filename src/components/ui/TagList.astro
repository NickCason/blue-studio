---
import Tag from './Tag.astro';
interface Props {
  tags?: readonly string[] | string[];
  /** When true, drops the top margin so tags can sit inline with sibling meta. */
  inline?: boolean;
}
const { tags, inline = false } = Astro.props;
---
{tags && tags.length > 0 && (
  <div class:list={['tag-list', { inline }]}>
    {tags.map((t) => <Tag tag={t} />)}
  </div>
)}
<style>
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }
  .tag-list.inline { margin-top: 0; }
</style>
