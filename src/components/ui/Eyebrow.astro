---
interface Props { kind?: 'rule' | 'plain'; class?: string; }
const { kind = 'plain', class: className = '' } = Astro.props;
---
<div class:list={['eyebrow-row', kind, className]}>
  <slot />
</div>
<style>
  .eyebrow-row {
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--accent-text);
    font-weight: 500;
    display: flex; align-items: center; gap: 10px;
  }
  .eyebrow-row.rule { justify-content: center; }
  .eyebrow-row.rule::before, .eyebrow-row.rule::after {
    content: ''; width: 24px; height: 1px; background: var(--accent); opacity: 0.5;
  }
</style>
