---
import { getEntry } from 'astro:content';
const site = await getEntry('site', 'site');
---
{site && (
  <section class="issue">
    <div class="label">Issue</div>
    <div class="num serif-italic">№ {site.data.issueNumber}<span class="d20" aria-hidden="true"><span>{site.data.issueNumber}</span></span></div>
    <div class="season">{site.data.season} · {site.data.year}</div>
  </section>
)}
<style>
  .issue { text-align: right; margin-top: 36px; padding-top: 24px; border-top: 1px dashed var(--border-soft); }
  .label { font-size: 9px; letter-spacing: var(--tracking-cap); text-transform: uppercase; color: var(--accent); opacity: 0.6; margin-bottom: 4px; }
  .num { font-size: 36px; line-height: 1; color: var(--fg); display: inline-flex; align-items: center; gap: 8px; font-variation-settings: 'SOFT' 100, 'opsz' 144; }
  .d20 {
    display: inline-flex; align-items: center; justify-content: center;
    width: 26px; height: 26px; position: relative;
  }
  .d20::before {
    content: ''; position: absolute; inset: 0;
    background: var(--accent);
    clip-path: polygon(50% 0%, 100% 38%, 82% 100%, 18% 100%, 0% 38%);
    opacity: 0.18;
  }
  .d20 span {
    position: relative; font-size: 11px; color: var(--accent); font-weight: 600;
    font-family: 'Fraunces Variable', serif; font-style: italic;
  }
  .season { font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase; color: var(--accent); opacity: 0.7; margin-top: 4px; }
</style>
