---
import type { CollectionEntry } from 'astro:content';
import MetaRow from '~/components/ui/MetaRow.astro';
import { formatRelative } from '~/lib/formatDate';

interface Props { post: CollectionEntry<'posts'>; }
const { post } = Astro.props;
if (post.data.type !== 'note') throw new Error('NoteCard requires note post');
const { Content } = await post.render();
---
<article class="note-card">
  <MetaRow items={['Note', formatRelative(post.data.publishedAt)]} />
  <a href={`/journal/${post.slug}/`} class="body-link">
    <blockquote class="note-body serif-italic"><Content /></blockquote>
  </a>
</article>
<style>
  .body-link { color: var(--fg); }
  .note-body {
    font-size: 19px;
    line-height: 1.55;
    color: var(--fg);
    border-left: 2px solid var(--accent);
    padding: 4px 0 4px 22px;
    max-width: 60ch;
    margin: 0;
    font-variation-settings: 'SOFT' 60, 'opsz' 24;
  }
  .note-body :global(p) { margin: 0; }
</style>
