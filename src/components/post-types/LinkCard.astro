---
import type { CollectionEntry } from 'astro:content';
import MetaRow from '~/components/ui/MetaRow.astro';
import TagList from '~/components/ui/TagList.astro';
import { formatRelative } from '~/lib/formatDate';

interface Props { post: CollectionEntry<'posts'>; }
const { post } = Astro.props;
if (post.data.type !== 'link') throw new Error('LinkCard requires link post');
const { Content } = await post.render();
---
<article class="link-card">
  <MetaRow items={['Link', formatRelative(post.data.publishedAt)]} />
  <div class="row">
    <div class="thumb" style={post.data.ogImage ? `background-image: url(${post.data.ogImage}); background-size: cover; background-position: center;` : ''}></div>
    <div class="content">
      <div class="source">{post.data.source}</div>
      <a href={post.data.url} target="_blank" rel="noopener" class="title">
        <h3 class="serif">{post.data.title}<span class="arrow"> ↗</span></h3>
      </a>
      <div class="comment serif-italic"><Content /></div>
      <TagList tags={post.data.tags} />
    </div>
  </div>
</article>
<style>
  .row { display: flex; gap: 24px; align-items: stretch; }
  .thumb {
    width: 140px; height: 140px; flex-shrink: 0;
    border-radius: var(--r-md);
    background:
      radial-gradient(ellipse at 30% 20%, rgba(232,228,223,0.22), transparent 50%),
      radial-gradient(circle at 70% 80%, rgba(15,15,20,0.6), transparent 60%),
      linear-gradient(135deg, var(--np-rose), var(--np-amethyst));
    box-shadow: var(--shadow-card);
  }
  .content { flex: 1; padding-top: 4px; }
  .source { font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase; color: var(--accent-text); opacity: 0.8; margin-bottom: 8px; }
  .title { color: var(--fg); display: inline-block; }
  .title h3 { font-size: 22px; line-height: 1.2; margin: 0 0 12px; font-variation-settings: 'SOFT' 60, 'opsz' 36; font-weight: 400; }
  .arrow { color: var(--accent); opacity: 0.7; }
  .comment { font-size: 15px; line-height: 1.55; color: var(--fg-soft); opacity: 0.85; max-width: 50ch; }
  .comment :global(p) { margin: 0; }
  @media (max-width: 640px) {
    .row { flex-direction: column; }
    .thumb { width: 100%; height: 160px; }
  }
</style>
