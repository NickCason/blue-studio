---
import type { CollectionEntry } from 'astro:content';
import MetaRow from '~/components/ui/MetaRow.astro';

interface Props { post: CollectionEntry<'posts'>; }
const { post } = Astro.props;
if (post.data.type !== 'quote') throw new Error('QuoteCard requires quote post');
const { Content } = await post.render();
---
<article class="quote-card">
  <div class="meta-center">
    <MetaRow items={[`From ${post.data.source}`]} />
  </div>
  <a href={`/journal/${post.slug}/`} class="body-link">
    <div class="quote">
      <span class="orn">✦</span>
      <p class="serif-italic"><Content /></p>
      <span class="orn">✦</span>
    </div>
  </a>
  <div class="attr">— {post.data.source}</div>
</article>
<style>
  .quote-card { text-align: center; padding: 20px 40px; }
  .meta-center { display: flex; justify-content: center; }
  .body-link { color: var(--fg); }
  .quote {
    display: flex; align-items: center; justify-content: center; gap: 14px;
    margin: 0 0 16px;
  }
  .quote p {
    font-size: 30px; line-height: 1.3; margin: 0; max-width: 28ch;
    font-variation-settings: 'SOFT' 100, 'opsz' 144; font-weight: 300;
    text-shadow: 0 2px 24px rgba(110,90,138,0.5);
  }
  :root[data-theme='light'] .quote p { text-shadow: none; }
  .orn { color: var(--accent); opacity: 0.7; font-size: 18px; }
  .quote p :global(p) { margin: 0; }
  .attr {
    font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--accent); opacity: 0.7;
  }
</style>
