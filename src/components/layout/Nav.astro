---
import ThemeToggle from './ThemeToggle.astro';
const { pathname } = Astro.url;
const isActive = (path: string) => pathname === path || pathname.startsWith(path + '/');
---
<nav class="site-nav">
  <a href="/" class="wordmark">blue<span class="wordmark__dot">·</span>studio</a>
  <div class="nav-links">
    <a href="/" class:list={['nav-link', { active: pathname === '/' }]}>Journal</a>
    <a href="/work/" class:list={['nav-link', { active: isActive('/work') && !isActive('/work/portfolio') }]}>Work</a>
    <a href="/work/portfolio/" class:list={['nav-link', { active: isActive('/work/portfolio') }]}>Portfolio</a>
    <a href="/about/" class:list={['nav-link', { active: isActive('/about') }]}>About</a>
    <ThemeToggle />
  </div>
</nav>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    padding: 18px 40px 16px;
    border-bottom: 1px solid var(--border-soft);
    backdrop-filter: blur(2px);
    position: relative;
    z-index: 5;
    width: 100%;
    box-sizing: border-box;
    flex-wrap: wrap;
  }
  .wordmark {
    font-family: 'Fraunces Variable', Georgia, serif;
    font-style: italic;
    font-size: clamp(18px, 2.4vw, 22px);
    letter-spacing: -0.01em;
    font-variation-settings: 'SOFT' 80, 'opsz' 80;
    color: var(--fg);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .wordmark__dot { color: var(--accent); padding: 0 4px; opacity: 0.85; }
  .nav-links {
    display: flex;
    gap: 22px;
    align-items: center;
    flex-shrink: 0;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .nav-link {
    color: var(--fg-soft);
    font-size: 11px;
    letter-spacing: var(--tracking-meta);
    text-transform: uppercase;
    font-weight: 500;
    opacity: 0.78;
    white-space: nowrap;
  }
  .nav-link:hover, .nav-link.active { opacity: 1; color: var(--accent-text); }
  @media (max-width: 640px) {
    .site-nav { padding: 14px 20px; gap: 16px; }
    .nav-links { gap: 14px; }
  }
  @media (max-width: 420px) {
    .nav-link { font-size: 10px; letter-spacing: 0.14em; }
  }
</style>
