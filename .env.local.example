# Copy this file to .env.local and fill in. .env.local is gitignored.

# Tina Cloud (https://app.tina.io → your project → Tokens)
TINA_PUBLIC_CLIENT_ID=
TINA_TOKEN=
NEXT_PUBLIC_TINA_BRANCH=main

# Formspree (https://formspree.io after creating a form)
PUBLIC_FORMSPREE_ENDPOINT=

# Tailnet TTS (used only by scripts/tts.mjs at author time, not at build)
TTS_ENDPOINT=http://precision-node4:8000
TTS_MODEL=speaches-ai/Kokoro-82M-v1.0-ONNX
TTS_VOICE=af_bella

# Site
PUBLIC_SITE_URL=https://bluestudio.space
PUBLIC_CONTACT_EMAIL=hello@bluestudio.space
